# SPDX-FileCopyrightText: 2021-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Locks the screen with i3lock, converting the wallpaper to PNG once and
# caching the result. The cache lives in the user directory rather than
# /tmp, where another user could plant a predictable file.
#
# File is sourced dynamically and the constant appears unused:
#  shellcheck disable=SC1090,SC2034
readonly \
	BASE_APP_VERSION=0.9.20260714 \
	BSH=/usr/local/bin/base.sh \
	IMG="$HOME"/dotfiles/pic/bg.jpg \
	PNG="${XDG_CACHE_HOME:-$HOME/.cache}"/lock.png
[ -r "$BSH" ] || {
	printf >&2 'Install Shellbase.\n'
	exit 1
}
. "$BSH"
validate_cmd i3lock
file_exists "$PNG" || {
	validate_cmd convert
	mkdir -p "$(dirname "$PNG")"
	convert "$IMG" "$PNG"
}
i3lock --image="$PNG" --tiling
