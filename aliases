# Checks whether the given command exists.
cmd_exists() {
	command -v "$1" >/dev/null 2>&1
}

alias vi=vim
if cmd_exists vivid; then
	LS_COLORS="$(vivid generate solarized-light)"
	export LS_COLORS
fi
if cmd_exists eza; then
	# The order is important. The alias applies to interactive shells only:
	#  shellcheck disable=SC2262
	alias ls='eza --group-directories-first'
	alias l='ls --classify --grid --long'
else
	# Detects whether ls takes the GNU or the BSD color flag. The alias does
	# not apply in the same parsing unit:
	#  shellcheck disable=SC2263
	if ls --color >/dev/null 2>&1; then
		colorflag=--color
	else
		colorflag=-G
	fi

	# The order is important. The flag expands when defined:
	#  shellcheck disable=SC2139
	alias ls="ls $colorflag"
	alias l='ls -lFh'
	unset colorflag
fi
alias la='l -a'
if cmd_exists bat; then
	alias cat='bat --style=plain'
fi

# Always enables colored grep output.
alias grep='grep --color=auto'
alias h=history
alias untar='tar -zxvf'
alias ipe='curl ipinfo.io/ip'
alias c=clear

# The path expands when defined:
#  shellcheck disable=SC2139
alias src-tmux="tmux source-file $HOME/.tmux.conf"

# The path expands when defined:
#  shellcheck disable=SC2139
alias src="source $HOME/.zshrc"
alias rsync='\
rsync \
--append-verify \
--archive \
--compress \
--human-readable \
--info=progress2 \
--partial \
--recursive \
--timeout=300 \
--verbose\
'
alias cmatrix='cmatrix -a -b -u 6 -C blue'
if cmd_exists brew; then
	alias bu='
brew update &&
brew upgrade --yes &&
brew upgrade --cask --greedy --yes &&
brew cleanup --prune=all
'
fi
if cmd_exists bfs; then
	alias find=bfs
fi
if cmd_exists python3; then
	# The path expands when defined:
	#  shellcheck disable=SC2139
	alias python="$(command -v python3)"
fi
